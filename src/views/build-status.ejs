<% var pageTitle = 'Build Status'; %>
<%- include('partials/head') %>
<%- include('partials/nav') %>

<div class="page-header">
  <div class="container">
    <div class="breadcrumb">
      <a href="/">Home</a> <span>/</span> <span>Build Status</span>
    </div>
    <h1>Build Status</h1>
    <p>Track the progress of VISTADEL framework development</p>
  </div>
</div>

<section class="section">
  <div class="container">
    <main class="markdown-content" style="max-width: 900px; margin: 0 auto;">
      <% if (content) { %>
        <%- content %>
      <% } else { %>
        <div class="empty-state">
          <h3>Status Unavailable</h3>
          <p>Build status information is not currently available.</p>
        </div>
      <% } %>
    </main>
  </div>
</section>

<%- include('partials/footer') %>
